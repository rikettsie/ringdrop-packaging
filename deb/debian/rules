#!/usr/bin/make -f

# Launchpad's sbuild sets HOME=/sbuild-nonexistent (non-writable).
# Pin CARGO_HOME and RUSTUP_HOME to /tmp so rustup and cargo land somewhere real.
export CARGO_HOME := /tmp/cargo-home
export RUSTUP_HOME := /tmp/rustup-home
CARGO := $(CARGO_HOME)/bin/cargo

%:
	dh $@

override_dh_auto_configure:
	curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
	    > /tmp/rustup-init.sh
	sh /tmp/rustup-init.sh -y --profile minimal --no-modify-path
	rm /tmp/rustup-init.sh
	mkdir -p .cargo
	printf '[source.crates-io]\nreplace-with = "vendored-sources"\n\n[source.vendored-sources]\ndirectory = "vendor"\n' \
	    > .cargo/config.toml
	python3 debian/fix-vendor-checksums.py
	python3 debian/patch-edition2024.py

override_dh_auto_build:
	$(CARGO) build --release --locked --offline

override_dh_auto_install:
	install -Dpm 0755 target/release/rdrop \
		debian/ringdrop/usr/bin/rdrop

override_dh_auto_test:
	# skip upstream tests during package build

override_dh_auto_clean:
	-$(CARGO) clean
